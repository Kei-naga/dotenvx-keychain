{
  "name": "dotenvx-keychain",
  "version": "0.1.1",
  "description": "A thin, easy-to-adopt dotenvx wrapper that isolates decryption keys into your OS native secret store for local development.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kei-naga/dotenvx-keychain.git"
  },
  "homepage": "https://github.com/Kei-naga/dotenvx-keychain#readme",
  "bugs": {
    "url": "https://github.com/Kei-naga/dotenvx-keychain/issues"
  },
  "keywords": [
    "dotenvx",
    "dotenv",
    "keychain",
    "secrets",
    "cli",
    "secret-management",
    "encryption",
    "ai-agents",
    "ai-security",
    "local-development",
    "credential-manager",
    "secret-service"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "dotenvx-keychain": "dist/index.js",
    "dxk": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@dotenvx/dotenvx": "^1.71.3",
    "keytar": "^7.9.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"*.{js,json,md,ts}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"*.{js,json,md,ts}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "pack:dry-run": "npm pack --dry-run",
    "pack:smoke": "npm run build && vitest run test/smoke/packagedCli.test.ts",
    "release:prepare": "bash ./scripts/prepare-release.sh",
    "test": "vitest run test/cli test/commands test/config test/secretStore",
    "test:real-store-smoke:linux": "bash ./scripts/test-real-store-smoke-linux.sh",
    "test:real-store-smoke": "vitest run test/smoke/realSecretStore.test.ts",
    "test:real-store-smoke:wsl": "bash ./scripts/test-real-store-smoke-wsl.sh",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^3.2.4"
  }
}
