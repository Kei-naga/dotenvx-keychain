{
  "name": "dotenvx-keychain",
  "version": "0.1.0",
  "description": "CLI wrapper that stores DOTENV_PRIVATE_KEY in native OS secret stores for dotenvx projects.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "dotenvx-keychain": "dist/index.js",
    "dxk": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@dotenvx/dotenvx": "^1.71.3",
    "keytar": "^7.9.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"*.{js,json,md,ts}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"*.{js,json,md,ts}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "pack:smoke": "npm pack --dry-run",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^3.2.4"
  }
}

